--// ============================================
--// ANTI-CHEAT BYPASS
--// ============================================
local function ToggleAntiCheat(enabled)
    if enabled and not Features.AntiCheat.Init then
        Features.AntiCheat.Init = true
        local success, err = pcall(function()
            assert(getgc and debug and debug.info and hookfunction and getconnections and newcclosure, "Missing required functions")
            
            -- Hook Analytics
            task.spawn(function()
                for _, v in pairs(getgc(true)) do
                    if typeof(v) == "function" then
                        local ok, src = pcall(function() return debug.info(v, "s") end)
                        if ok and type(src) == "string" and string.find(src, "AnalyticsPipelineController") then
                            hookfunction(v, newcclosure(function() return wait(9e9) end))
                        end
                    end
                end
            end)
            
            -- Hook Remotes
            task.spawn(function()
                local ok, remote = pcall(function()
                    return ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("AnalyticsPipeline"):WaitForChild("RemoteEvent")
                end)
                if ok and remote then
                    for _, conn in pairs(getconnections(remote.OnClientEvent)) do
                        if conn and conn.Function then
                            pcall(function() hookfunction(conn.Function, newcclosure(function() end)) end)
                        end
                    end
                end
            end)
            
            -- Hook Logs
            task.spawn(function()
                for _, conn in pairs(getconnections(LogService.MessageOut)) do
                    if conn and conn.Function then
                        pcall(function() hookfunction(conn.Function, newcclosure(function() end)) end)
                    end
                end
            end)
            
            -- Hook Errors
            task.spawn(function()
                for _, conn in ipairs(getconnections(ScriptContext.Error)) do
                    pcall(function() conn:Disable() end)
                end
                pcall(function()
                    hookfunction(ScriptContext.Error.Connect, newcclosure(function() return nil end))
                end)
            end)
            
            -- Hook Kick
            task.spawn(function()
                for _, name in ipairs({"Kick", "kick"}) do
                    local fn = LocalPlayer[name]
                    if type(fn) == "function" then
                        local oldkick
                        oldkick = hookfunction(fn, newcclosure(function(self, ...)
                            if self == LocalPlayer then return end
                            return oldkick(self, ...)
                        end))
                    end
                end
            end)
        end)
        
        if success then
            Library:Notify({ Title = "Anti-Cheat", Description = "Successfully disabled!", Time = 3 })
        else
            warn("Anti-Cheat failed: " .. tostring(err))
        end
    end
    Features.AntiCheat.Enabled = enabled
end

