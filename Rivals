--// AUTO LOADOUT
--// ============================================
local weaponPickRemote = ReplicatedStorage.Remotes.Replication.Fighter.PickWeapons
local prePickRemote = ReplicatedStorage.Remotes.Duels.PickWeaponsAheadOfTime

local function ToggleAutoLoadout(enabled)
    if enabled then
        if Features.AutoLoadout.Conn then return end
        Features.AutoLoadout.Conn = task.spawn(function()
            while task.wait(0.1) do
                if not Features.AutoLoadout.Enabled then continue end
                
                local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
                local selectionInterface = playerGui and playerGui:FindFirstChild("PickWeapons", true)
                
                if selectionInterface and selectionInterface.Visible then
                    local payload = {}
                    for index, weaponName in next, Config.WeaponChoices do
                        if weaponName and weaponName ~= "" then
                            payload[index] = weaponName
                        end
                    end
                    
                    if next(payload) then
                        pcall(function()
                            weaponPickRemote:FireServer(payload)
                            prePickRemote:FireServer(payload)
                        end)
                    end
                    
                    repeat task.wait(0.1) until not (selectionInterface and selectionInterface.Visible)
                end
            end
        end)
    else
        -- Just stop checking, the loop will skip
    end
    Features.AutoLoadout.Enabled = enabled
end

