--// ============================================
--// SILENT AIM
--// ============================================
local function FetchEntities()
    local entities = {}
    for _, v in pairs(workspace:GetChildren()) do
        if v:FindFirstChildOfClass("Humanoid") then
            table.insert(entities, v)
        elseif v.Name == "HurtEffect" then
            for _, child in pairs(v:GetChildren()) do
                if child.ClassName ~= "Highlight" then
                    table.insert(entities, child)
                end
            end
        end
    end
    return entities
end

local function GetNearest()
    local target, dist = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, entity in pairs(FetchEntities()) do
        if entity ~= LocalPlayer.Character and entity:FindFirstChild("HumanoidRootPart") then
            local part = entity:FindFirstChild(Config.SilentAimPart)
            if part then
                local pos, visible = Camera:WorldToViewportPoint(part.Position)
                if visible then
                    local mag = (center - Vector2.new(pos.X, pos.Y)).Magnitude
                    if mag < dist and mag < Config.SilentAimFOV then
                        target, dist = entity, mag
                    end
                end
            end
        end
    end
    return target
end

local function SilentAimHook(...)
    local args = {...}
    local override = (args[4] == 999) and (function()
        local aim = GetNearest()
        local node = aim and aim:FindFirstChild(Config.SilentAimPart)
        return node and node.Position
    end)()
    
    if override then
        args[3] = override
    end
    
    return Features.SilentAim.OldRaycast(table.unpack(args))
end

local function ToggleSilentAim(enabled)
    if enabled then
        if not Features.SilentAim.OldRaycast then
            Features.SilentAim.OldRaycast = Utility.Raycast
            Utility.Raycast = SilentAimHook
        end
    else
        if Features.SilentAim.OldRaycast then
            Utility.Raycast = Features.SilentAim.OldRaycast
            Features.SilentAim.OldRaycast = nil
        end
    end
    Features.SilentAim.Enabled = enabled
    Library:Notify({ Title = "Silent Aim", Description = enabled and "Enabled!" or "Disabled!", Time = 2 })
end

