--// FAST FIRE (NEW)
--// ============================================
local function ToggleFastFire(enabled)
    if enabled then
        local gunExceptions = { ["Sniper"] = true, ["Crossbow"] = true, ["Bow"] = true, ["RPG"] = true }
        
        for name, data in pairs(ItemLibrary) do
            if typeof(data) == "table" and not gunExceptions[name] then
                -- Save originals
                if not Features.FastFire.Original[name] then
                    Features.FastFire.Original[name] = {
                        ShootSpread = data.ShootSpread,
                        ShootAccuracy = data.ShootAccuracy,
                        ShootRecoil = data.ShootRecoil,
                        ShootCooldown = data.ShootCooldown,
                        ShootBurstCooldown = data.ShootBurstCooldown,
                        AttackCooldown = data.AttackCooldown,
                        SwingCooldown = data.SwingCooldown,
                        Cooldown = data.Cooldown,
                        RecoveryTime = data.RecoveryTime,
                        ResetTime = data.ResetTime
                    }
                end
                
                -- Apply fast fire
                if data.ShootSpread then data.ShootSpread = 0 end
                if data.ShootAccuracy then data.ShootAccuracy = 0 end
                if data.ShootRecoil then data.ShootRecoil = 0 end
                if data.ShootCooldown then data.ShootCooldown = 0.001 end
                if data.ShootBurstCooldown then data.ShootBurstCooldown = 0.001 end
                if data.AttackCooldown then data.AttackCooldown = 0.001 end
                if data.SwingCooldown then data.SwingCooldown = 0.001 end
                if data.Cooldown then data.Cooldown = 0.001 end
                if data.RecoveryTime then data.RecoveryTime = 0.001 end
                if data.ResetTime then data.ResetTime = 0.001 end
            end
        end
        Library:Notify({ Title = "Fast Fire", Description = "Enabled!", Time = 2 })
    else
        -- Restore originals
        for name, orig in pairs(Features.FastFire.Original) do
            local data = ItemLibrary[name]
            if data then
                for key, val in pairs(orig) do
                    data[key] = val
                end
            end
        end
        Library:Notify({ Title = "Fast Fire", Description = "Disabled!", Time = 2 })
    end
    Features.FastFire.Enabled = enabled
end

--// ============================================
--// WALLBANG (WORKING)
--// ============================================
local function FindTarget()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    local closest, closestDist = nil, 200
    for _, player in next, Players:GetPlayers() do
        if player == LocalPlayer then continue end
        if player:GetAttribute("TeamID") == LocalPlayer:GetAttribute("TeamID") then continue end
        
        local char = player.Character
        if not char then continue end
        
        local root = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChildWhichIsA("Humanoid")
        
        if not (root and head and hum and hum.Health > 0) then continue end
        
        local dist = (myRoot.Position - root.Position).Magnitude
        if dist < closestDist then
            closestDist = dist
            closest = player
        end
    end
    return closest
end

local function DesyncStart(target)
    if Features.Wallbang.Conn then Features.Wallbang.Conn:Disconnect() end
    Features.Wallbang.Active = true
    Features.Wallbang.Target = target
    
    Features.Wallbang.Conn = RunService.Heartbeat:Connect(function()
        if not Features.Wallbang.Active then return end
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        if not targetRoot then
            -- DesyncStop()
            return
        end
        
        local oldCFrame = myRoot.CFrame
        local oldVel = myRoot.Velocity
        local oldRotVel = myRoot.RotVelocity
        
        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, -5, 0)
        
        RunService:BindToRenderStep("__restore", 101, function()
            myRoot.CFrame = oldCFrame
            myRoot.Velocity = oldVel
            myRoot.RotVelocity = oldRotVel
            RunService:UnbindFromRenderStep("__restore")
        end)
    end)
end

local function DesyncStop()
    Features.Wallbang.Active = false
    Features.Wallbang.Target = nil
    if Features.Wallbang.Conn then
        Features.Wallbang.Conn:Disconnect()
        Features.Wallbang.Conn = nil
    end
    if Features.Wallbang.Task then
        task.cancel(Features.Wallbang.Task)
        Features.Wallbang.Task = nil
    end
end

local function WallbangHook(self, ...)
    local results = {Features.Wallbang.OldFunc(self, ...)}
    
    if not self.ClientFighter or not self.ClientFighter.IsLocalPlayer then
        return unpack(results)
    end
    
    local bulletData = results[3]
    if not bulletData or typeof(bulletData) ~= "table" then
        return unpack(results)
    end
    
    results[4] = true
    
    if not Features.Wallbang.Enabled then
        return unpack(results)
    end
    
    local target = FindTarget()
    if not target or not target.Character then
        return unpack(results)
    end
    
    -- Desync
    if not Features.Wallbang.Active or Features.Wallbang.Target ~= target then
        DesyncStart(target)
        task.wait(0.1)
    end
    
    if Features.Wallbang.Task then
        task.cancel(Features.Wallbang.Task)
        Features.Wallbang.Task = nil
    end
    
    -- Bullet Redirection
    local targetHead = target.Character:FindFirstChild("Head")
    if targetHead then
        local pos = targetHead.Position
        local offsetPos = pos - Vector3.new(0, 5, 0)
        local lookCFrame = CFrame.lookAt(offsetPos, pos)
        local randomOffset = CFrame.new(pos + Vector3.new(math.random(), math.random(), math.random()))
        
        bulletData[utf8.char(0)] = Utility:EncodeCFrame(CFrame.new(offsetPos, pos) * CFrame.Angles(lookCFrame:ToOrientation()))
        bulletData[utf8.char(1)] = Utility:EncodeCFrame(CFrame.new(pos) * CFrame.Angles(lookCFrame:ToOrientation()))
        bulletData[utf8.char(2)] = targetHead
        bulletData[utf8.char(3)] = Utility:EncodeCFrame(targetHead.CFrame:ToObjectSpace(randomOffset))
    end
    
    Features.Wallbang.Task = task.delay(0.15, DesyncStop)
    
    return unpack(results)
end

local function ToggleWallbang(enabled)
    if enabled then
        if not Features.Wallbang.OldFunc then
            Features.Wallbang.OldFunc = GunModule.StartShooting
            GunModule.StartShooting = WallbangHook
        end
        Library:Notify({ Title = "Wallbang", Description = "Enabled!", Time = 2 })
    else
        if Features.Wallbang.OldFunc then
            GunModule.StartShooting = Features.Wallbang.OldFunc
            Features.Wallbang.OldFunc = nil
        end
        DesyncStop()
        Library:Notify({ Title = "Wallbang", Description = "Disabled!", Time = 2 })
    end
    Features.Wallbang.Enabled = enabled
end

